{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "includes": ["**", "!**/renovate.json"]
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": {
        "noUndeclaredVariables": "error",
        "noNodejsModules": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noTemplateCurlyInString": "off"
      },
      "performance": {
        "useTopLevelRegex": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 20
          }
        }
      }
    }
  },
  "formatter": {
    "includes": ["**", "!**/package.json", "!**/license-checker-config.json"],
    "indentStyle": "space",
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    },
    "globals": ["os"]
  },
  "overrides": [
    {
      "includes": ["**/test/**/*.js"],
      "javascript": {
        "globals": ["afterEach", "afterAll", "beforeEach", "beforeAll", "describe", "it"]
      },
      "linter": {
        "rules": {
          "style": {
            "noDoneCallback": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/commands/**/*.js"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/fastly/service.js"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    }
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  }
}
